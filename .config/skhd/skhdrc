shift + cmd - y : yabai --stop-service; yabai --start-service; sudo yabai --load-sa;

# change window focus within space
alt - j : yabai -m window --focus south
alt - k : yabai -m window --focus north
alt - h : yabai -m window --focus west
alt - l : yabai -m window --focus east

# swap windows
shift + alt - j : yabai -m window --swap south
shift + alt - k : yabai -m window --swap north
shift + alt - h : yabai -m window --swap west
shift + alt - l : yabai -m window --swap east

# maximize a window
alt - f : yabai -m window --toggle zoom-fullscreen

# fast focus desktop
alt - 1 : yabai -m space --focus 1
alt - 2 : yabai -m space --focus 2
alt - 3 : yabai -m space --focus 3
alt - 4 : yabai -m space --focus 4
alt - 5 : yabai -m space --focus 5
alt - 6 : yabai -m space --focus 6
alt - 7 : yabai -m space --focus 7
alt - 8 : yabai -m space --focus 8
alt - 9 : yabai -m space --focus 9
alt - 0 : yabai -m space --focus 10

# move to prev and next space
alt - a : yabai -m space --focus prev;
alt - d : yabai -m space --focus next;

# move window to prev and next space
shift + alt - a : yabai -m window --space prev; yabai -m space --focus prev;
shift + alt - d : yabai -m window --space next; yabai -m space --focus next;

# move window to space #
shift + alt - 1 : yabai -m window --space 1; yabai -m space --focus 1
shift + alt - 2 : yabai -m window --space 2; yabai -m space --focus 2
shift + alt - 3 : yabai -m window --space 3; yabai -m space --focus 3
shift + alt - 4 : yabai -m window --space 4; yabai -m space --focus 4
shift + alt - 5 : yabai -m window --space 5; yabai -m space --focus 5
shift + alt - 6 : yabai -m window --space 6; yabai -m space --focus 6
shift + alt - 7 : yabai -m window --space 7; yabai -m space --focus 7
shift + alt - 8: yabai -m window --space 8; yabai -m space --focus 8
shift + alt - 9 : yabai -m window --space 9; yabai -m space --focus 9
shift + alt - 0 : yabai -m window --space 10; yabai -m space --focus 10

# toggle window float
alt - t : yabai -m window --toggle float --grid 4:4:1:1:2:2

# Applications launch
shift + cmd - return : open /Applications/Zen.app -n --args --blank-window;
shift + cmd - b : open /Applications/Zen.app -n;

cmd - return : open /Applications/Ghostty.app -n;
shift + cmd - d : open /Applications/vesktop.app -n;
shift + cmd - k : id=$(yabai -m query --windows | jq -r '[.[] | select(.app == "KeePassXC")] | first | .id'); [ -n "$id" ] && yabai -m window "$id" --space mouse && yabai -m window --focus "$id" || open /Applications/keepassxc.app;
ctrl + cmd - f : open ~;
shift + cmd - n : /Applications/Ghostty.app/Contents/MacOS/ghostty -e nvim
shift + cmd - m : open /Applications/Spotify.app;

